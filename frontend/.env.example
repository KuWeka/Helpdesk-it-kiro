# Frontend Environment Variables
# Copy this file to .env.local and fill in the values

# Backend API URL (In Vercel, set this to your Railway app URL, e.g., https://your-backend.railway.app/api)
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# Socket.io Server URL (In Vercel, set this to your Railway app URL, e.g., https://your-backend.railway.app)
NEXT_PUBLIC_SOCKET_URL=http://localhost:5000

# App Configuration
NEXT_PUBLIC_APP_NAME=PoldaHelp Kalsel
NEXT_PUBLIC_DEFAULT_LOCALE=id
